function _checkout_or_die() {
  # we want to check out a branch.  Maybe there is already a
  # worktree.  Maybe we need to create a worktree.  Let's do
  # whatever is necessary.
  local BRNAME BRDIR
  BRNAME="$1"; shift
  # Do we already have a worktree?
  BRDIR="$(_get_branch_directory "${BRNAME}")"
  if [[ -z "${BRANCHES_DIR}" ]]; then
    _git worktree add "${BRANCHES_DIR}/${BRNAME}"
    BRDIR="$(_get_branch_directory "${BRNAME}")"
  fi
  if [[ -z "${BRDIR}" ]]; then
    _die "Could not check out ${BRNAME}"
  fi
}

HELP+=("update: integrate upstream changes into this branch.")
function gee__update() {
  local CURRENT_BRANCH
  CURRENT_BRANCH="$("${GIT}" branch --show-current)"
  if [[ -z "${CURRENT_BRANCH}" ]]; then
    _die "Not in a git branch directory."
  fi
  MASTER_BRANCH="$("${GIT}" worktree list | grep -w \\\[master\\\] | awk '{print $1}' )"
  if [[ -z "${MASTER_BRANCH}" ]]; then
    MASTER_BRANCH="${BRANCHES_DIR}/master"  # default place where master branch should reside.
  fi
  local UNCOMMITTED
  UNCOMMITTED="$("${GIT}" status --short -uall | wc -l)"
  if [[ "${UNCOMMITTED}" -gt 0 ]]; then
    echo "Branch contains ${UNCOMMITTED} uncommitted changes:"
    _git status --short -uall
    echo "Run \"gee commit\" and try again."
    exit 1
  fi
  _git fetch upstream
  _checkout_or_die master
  _git merge upstream/master
  _checkout_or_die "${CURRENT_BRANCH}"
  _git rebase master
  _git pull origin "${CURRENT_BRANCH}"
  _git push origin "${CURRENT_BRANCH}"
}

HELP+=("config: configure _git and _gh tools.")
function gee__config() {
  _gh config "$@"
}

HELP+=("whatsout: list locally changed files in this branch.")
function gee__whatsout() {
  _git diff --name-only master
}

# Report how many commits this branch is ahead/behind master.
function branch_ahead_behind() {
  local branch; branch="$1"
  local remote; remote="$("${GIT}" config branch."${branch}".remote)"
  local obr; obr=""
  if [[ -z "$remote" ]]; then
    obr=master
  else
    local mergebr; mergebr="$("${GIT}" config branch."${branch}".merge | cut -d / -f 3)"
    obr=${remote}/${mergebr}
  fi
  local -a counts
  read -r -a counts < <("${GIT}" rev-list --left-right --count "${branch}...${obr}")
  echo -e "${branch}:\t${counts[0]} ahead, ${counts[1]} behind ${obr}"
}

# Get info about all branches.
HELP+=("lsbranches: list information about each branch.")
function gee__lsb() { gee__lsbranches "$@"; }
function gee__lsbr() { gee__lsbranches "$@"; }
function gee__lsbranches() {
  local -a branches;
  mapfile -t branches < <( "${GIT}" branch --format "%(refname:short)")
  local br
  for br in "${branches[@]}"; do
    branch_ahead_behind "${br}"
  done
}

HELP+=("commit: commit all changes in this branch")
function gee__push() { gee__commit "$@"; }
function gee__commit() {
  local CURRENT_BRANCH
  CURRENT_BRANCH="$("${GIT}" branch --show-current)"
  BRANCH_DIR="$(_get_branch_directory "${CURRENT_BRANCH}")"
  echo "${BRANCH_DIR}" "${HOME}"
  if [[ "${BRANCH_DIR}" != "${HOME}" ]]; then
    _git add --all
  else
    echo "Skipped \"git add --all\" because branch is home dir."
  fi
  NOSTACK=1 _git commit "$@"
  # We always push upstream so that users have a backup in case they lose their
  # laptop:
  _git pull origin "${CURRENT_BRANCH}"
  _git push origin "${CURRENT_BRANCH}"
}

HELP+=("send: Send a PR out for review.")
function gee__mail() { gee__send "$@"; }
function gee__send() {
  if "${GH}" pr view > /dev/null; then
    echo "PR already exists, use \"git commit\" to update."
    _gh pr view
    exit 1
  fi

  local PARENT_BRANCH CURRENT_BRANCH MERGE_BASE NUM_COMMITS
  PARENT_BRANCH="$(_get_parent_branch)"
  CURRENT_BRANCH="$("${GIT}" branch --show-current)"
  MERGE_BASE="$("${GIT}" merge-base "${PARENT_BRANCH}" "${CURRENT_BRANCH}")"

  UNCOMMITTED="$("${GIT}" status --short -uall | wc -l)"
  if [[ "${UNCOMMITTED}" -gt 0 ]]; then
    echo "Branch contains ${UNCOMMITTED} uncommitted changes:"
    _git status --short -uall
    echo "Run \"gee commit\" and try again."
    exit 1
  fi

  NUM_COMMITS="$("${GIT}" log --oneline "${PARENT_BRANCH}..${CURRENT_BRANCH}" | wc -l)"
  if [[ "${NUM_COMMITS}" -eq 0 ]]; then
    echo "No changes in this branch."
    exit 1
  fi
  if [[ "${NUM_COMMITS}" -gt 1 ]]; then
    local YN
    echo "There are ${NUM_COMMITS} commits outstanding."
    read -rp "Do you want to squash before sending this PR? (y/N)  " YN
    if [[ "$YN" =~ ^[yY] ]]; then
      gee__squash
    fi
  fi

  _gh pr create
  # _gh pr checks  # not sure why this is problematic.
  _gh pr view
  echo "Add reviewers."
}
  

function gee__submit() { gee__merge "$@"; }
function gee__merge() {
  _gh pr checks
  _gh pr merge --squash
  _git pull
}

function main() {
  local cmdname="$1"; shift
  if type "gee__${cmdname}" >/dev/null 2>&1; then
    _startup_checks
    "gee__${cmdname}" "$@"
  else
    echo "Unknown command ${cmdname}"
    echo ""
    echo "Commands:"
    for h in "${HELP[@]}"; do
      echo "  $h"
    done
    exit 2
  fi
}

main "$@"
